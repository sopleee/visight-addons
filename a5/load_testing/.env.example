# Environment Variables for Locust Load Testing
# Copy this file to .env and fill in your values

# ===== MODAL CONFIGURATION =====
# Note: AWS credentials are stored in Modal Secrets ("s3-bucket-secret")
# You don't need to provide them here for load testing!

# Only needed if you want to deploy/manage Modal apps from this machine
# For load testing only, you can leave these empty
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
# Set to 'dev' or 'prod'
MODAL_ENV=dev

# ===== VIDEO URLS FOR TESTING =====
# Google Drive share links to test videos
# Low frame scenario: shorter video or lower FPS extraction
LOW_FRAME_VIDEO_URL=https://drive.google.com/file/d/YOUR_LOW_FRAME_VIDEO_ID/view?usp=sharing

# High frame scenario: longer video or higher FPS extraction
HIGH_FRAME_VIDEO_URL=https://drive.google.com/file/d/YOUR_HIGH_FRAME_VIDEO_ID/view?usp=sharing

# ===== MODAL ENDPOINT =====
# REQUIRED: The Modal endpoint URL (get this after deploying model_server.py)
# For direct inference (locustfile.py):
#   Format: https://your-username--visight-yolo-dev-inference.modal.run
# For queue-based inference (locustfile_queue.py):
#   Format: https://your-username--visight-yolo-test-dev.modal.run
# This is the ONLY required variable for load testing!
MODAL_ENDPOINT_URL=https://your-endpoint.modal.run

# ===== LOAD TEST CONFIGURATION =====
# Number of concurrent users to simulate
LOCUST_USERS=5

# Spawn rate (users per second)
LOCUST_SPAWN_RATE=1

# Test duration (e.g., 10m, 1h)
LOCUST_RUN_TIME=10m

# ===== SCENARIO CONFIGURATION =====
# Enable/disable test scenarios
ENABLE_LOW_FRAME=true
ENABLE_HIGH_FRAME=true

# Low frame scenario parameters
LOW_FRAME_FPS=6
LOW_FRAME_BATCH_SIZE=50

# High frame scenario parameters
HIGH_FRAME_FPS=24
HIGH_FRAME_BATCH_SIZE=200

# ===== QUEUE-BASED CONFIGURATION (for locustfile_queue.py) =====
# Seconds between status checks when polling for job completion
POLL_INTERVAL=10

# Maximum time to wait for job completion (seconds)
MAX_POLL_TIME=600
