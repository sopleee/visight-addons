MODAL_SUBMIT_URL=https://ymoola--visight-yolo-test-prod-submit-job.modal.run
MODAL_CHECK_STATUS_URL=https://ymoola--visight-yolo-test-prod-check-status.modal.run
MODAL_DOWNLOAD_URL=https://ymoola--visight-yolo-test-prod-download-result.modal.run

# S3 upload target for user-submitted videos (used by /api/upload)
UPLOAD_S3_BUCKET=your-upload-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET

# Optional: cap upload size in bytes (default ~400MB)
MAX_UPLOAD_BYTES=400000000
